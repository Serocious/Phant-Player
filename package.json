{
  "name": "phant",
  "version": "0.3.0",
  "description": "Phant - a modern, pure-dark local music player",
  "main": "dist-electron/main/main.js",
  "type": "commonjs",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:vite\" \"npm:dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "wait-on tcp:5173 && tsc -p tsconfig.electron.json && electron .",
    "compile": "tsc -p tsconfig.electron.json && vite build",
    "build": "npm run compile && electron-builder",
    "build:dir": "npm run compile && electron-builder --dir"
  },
  "dependencies": {
    "music-metadata": "7.14.0",
    "sql.js": "^1.12.0"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/sql.js": "^1.4.9",
    "@vitejs/plugin-react": "^4.3.3",
    "concurrently": "^9.1.0",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.sean.phant",
    "productName": "Phant",
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json",
      "!config.json",
      "!node_modules/**/{CHANGELOG.md,README.md,readme.md,*.d.ts,*.map,test,tests,__tests__,*.flow,LICENSE,LICENSE.txt}",
      "!**/{.DS_Store,.git,.gitignore,.gitattributes,*.log}"
    ],
    "asarUnpack": [
      "node_modules/sql.js/dist/sql-wasm.wasm",
      "node_modules/sql.js/dist/sql-wasm.js"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico",
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Phant"
    }
  }
}
